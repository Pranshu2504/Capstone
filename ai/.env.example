# ── Model selection (all swappable via env) ──────────────────────────────────
BODY_MESH_MODEL=hmr2               # hmr2 | smplest-x (CUDA server only)
FACE_ID_MODEL=mica                 # mica | deca (research only)
SEGMENTATION_MODEL=sam2-tiny       # sam2-tiny | mediapipe-selfie | rembg
KEYPOINT_MODEL=vitpose-base        # vitpose-base | rtmpose-s
CLOTHED_MODEL=sifu                 # sifu | econ | none
BACKEND_DEVICE=mps                 # mps | cpu | cuda
N_KEYFRAMES=12
LOW_MEM_MODE=false                 # auto-set if psutil detects <12 GB free

# ── PyTorch MPS ───────────────────────────────────────────────────────────────
PYTORCH_ENABLE_MPS_FALLBACK=1

# ── File storage (MinIO local or AWS S3) ─────────────────────────────────────
S3_BUCKET=zora-assets
S3_ENDPOINT_URL=http://localhost:9000   # leave blank for real AWS S3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# ── Redis job queue ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Ollama (LLM, not used in body-mesh pipeline) ─────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_VISION_MODEL=llava:13b

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=style_embeddings

# ── Privacy ───────────────────────────────────────────────────────────────────
PURGE_RAW_INPUTS=true
DEBUG_KEEP_RAW=false               # set true to retain raw frames for debugging

# ── Model weight paths (local clones) ─────────────────────────────────────────
HMR2_MODEL_PATH=/opt/4D-Humans
MICA_ONNX_PATH=/opt/MICA/mica_resnet50.onnx
SAM2_CHECKPOINT=/opt/sam2/checkpoints/sam2_hiera_tiny.pt
SAM2_CONFIG=/opt/sam2/configs/sam2/sam2_hiera_t.yaml
SMPLX_MODEL_DIR=/opt/smplx_models         # contains SMPLX_NEUTRAL.npz etc.
SIFU_ROOT=/opt/SIFU
VITPOSE_CONFIG=/opt/mmpose/configs/body/2d_kpt_sview_rgb_img/topdown_heatmap/halpe/ViTPose_base_halpe_256x192.py
VITPOSE_CHECKPOINT=/opt/mmpose/checkpoints/vitpose_base_halpe.pth
